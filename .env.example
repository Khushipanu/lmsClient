# Backend API URL (no trailing slash)
# Example for local development: http://localhost:5000
# Example for production: https://learningmanagementserver.onrender.com
VITE_API_URL=http://localhost:5000

# Razorpay public key (get from Razorpay Dashboard → API Keys)
VITE_RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_HERE

# Google reCAPTCHA v2 site key
# Use Google's test key for local development: 6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI
VITE_RECAPTCHA_SITE_KEY=6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI
